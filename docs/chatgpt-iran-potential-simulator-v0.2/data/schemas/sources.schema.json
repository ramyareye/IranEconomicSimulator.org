{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IPS Sources Registry",
  "type": "object",
  "required": [
    "sources"
  ],
  "properties": {
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "type",
          "url",
          "notes"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "retrieved_at": {
            "type": "string"
          }
        }
      }
    }
  }
}